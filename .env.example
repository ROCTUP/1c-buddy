# 1C Buddy - Сhat, MCP server and OPENAI API compatible gateway

# code.1c.ai upstream API token (from https://code.1c.ai)
ONEC_AI_TOKEN=

# Gateway API key that clients must present (Authorization: Bearer <OPENAI_COMPAT_API_KEY>)
OPENAI_COMPAT_API_KEY=

# Public model id presented to clients at /v1/models
PUBLIC_MODEL_ID=1c-buddy

# Optional default BSP version included in MCP prompts.
# Leave empty to disable.
DEFAULT_BSP_VERSION=
